HOST=localhost

# DEV ONLY — allows the React dev server to accept requests from any hostname
# (needed when the proxy forwards requests from a separate Express server on a
# different port, e.g. localhost:4000 → localhost:3000 in development).
#
# ⚠️  REMOVE THIS LINE BEFORE ANY PRODUCTION DEPLOYMENT.
# Leaving it in production allows arbitrary hosts to forward requests through
# your dev server, which is a security risk.
DANGEROUSLY_DISABLE_HOST_CHECK=true
